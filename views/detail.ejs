<!DOCTYPE html>
<html lang="id">
<head>
    <%- include('layout/head') %>
</head>
<body class="pb-24 animate-fade">
    <header>
        <nav class="fixed top-0 w-full z-50 p-4 lg:p-6 flex justify-between items-center bg-gradient-to-b from-black/90 to-transparent transition-all duration-300">
            <a href="/" class="bg-black/40 hover:bg-black/60 p-2.5 lg:p-3 rounded-full backdrop-blur text-white border border-white/10 transition">
                <svg class="w-5 h-5 md:w-6 md:h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path></svg>
            </a>
        </nav>

        <div class="relative w-full h-[60vh] md:h-[70vh]">
            <div class="absolute inset-0 bg-purple-900/20"></div>
            <img src="<%= anime.img %>" alt="<%= anime.title %>" class="w-full h-full object-cover opacity-60 mask-image-b">
            <div class="absolute inset-0 bg-gradient-to-t from-[#0b0c15] via-[#0b0c15]/50 to-transparent"></div>

            <div class="absolute bottom-0 left-0 w-full p-5 md:p-10 lg:p-16 animate-slide-up">
                <div class="container mx-auto flex flex-col md:flex-row gap-6 lg:gap-10 items-center md:items-end">
                    <img src="<%= anime.img %>" alt="<%= anime.title %>" class="hidden md:block w-40 lg:w-56 rounded-xl shadow-2xl border-2 border-white/10">

                    <div class="flex-1 text-center md:text-left w-full">
                        <div class="flex flex-wrap justify-center md:justify-start gap-2 lg:gap-3 mb-3 lg:mb-4">
                            <span class="px-2.5 py-0.5 lg:px-3 lg:py-1 rounded text-[10px] lg:text-xs font-bold uppercase tracking-wide bg-white text-black"><%= anime.status %></span>
                            <span class="px-2.5 py-0.5 lg:px-3 lg:py-1 rounded text-[10px] lg:text-xs font-bold bg-yellow-500/20 text-yellow-300 border border-yellow-500/30">&starf; <%= anime.rating %></span>
                        </div>
                        <h1 class="text-3xl md:text-5xl lg:text-6xl font-bold text-white mb-3 lg:mb-4 leading-tight"><%= anime.title %></h1>
                        <div class="flex flex-wrap justify-center md:justify-start gap-2 lg:gap-3 text-xs md:text-sm lg:text-base text-slate-300">
                            <% anime.genres.forEach(genre => { %>
                                <span class="hover:text-purple-400 transition cursor-default">#<%= genre.title %></span>
                            <% }) %>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </header>

    <main class="container mx-auto px-5 md:px-10 lg:px-16 -mt-2 md:-mt-8 relative z-10 space-y-8 lg:space-y-12">
        <article class="animate-slide-up" style="animation-delay: 0.1s;">
            <section class="text-sm md:text-base lg:text-lg text-slate-300 leading-relaxed bg-slate-900/40 p-5 md:p-8 lg:p-10 rounded-2xl border border-white/5 backdrop-blur-sm">
                <%- anime.desc %>
            </section>
        </article>

        <section class="animate-slide-up" style="animation-delay: 0.2s;">
            <header class="flex justify-between items-center mb-4 lg:mb-6">
                <h2 class="font-bold text-white text-lg md:text-xl lg:text-2xl">Episode List</h2>
                <span class="text-xs md:text-sm lg:text-base text-slate-500"><%= anime.episodes.length %> Episode</span>
            </header>

            <div class="bg-slate-900/20 border border-white/5 rounded-2xl p-4 md:p-6 lg:p-8 max-h-[500px] lg:max-h-[700px] overflow-y-auto custom-scroll">
                <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 xl:grid-cols-6 gap-3 md:gap-4 lg:gap-5">
                    <% if(anime.episodes.length > 0) { %>
                        <% anime.episodes.forEach(eps => { %>
                            <a href="/watch/<%= anime.slug %>/<%= eps.slug %>" class="bg-slate-800/60 hover:bg-purple-600 transition border border-white/5 hover:border-purple-500 rounded-xl p-3 md:p-4 text-center group relative overflow-hidden">
                                <span class="block text-[10px] md:text-xs text-slate-500 group-hover:text-purple-200 uppercase tracking-widest mb-1 md:mb-2">Episode</span>
                                <span class="block text-xl md:text-2xl lg:text-3xl font-bold text-white"><%= eps.title.replace(/\D/g, '') %></span>
                                <div class="absolute inset-0 bg-purple-500/10 opacity-0 group-hover:opacity-100 transition"></div>
                            </a>
                        <% }) %>
                    <% } else { %>
                        <p class="text-slate-500 col-span-full text-center py-10 md:py-16 lg:py-20">Belum ada episode.</p>
                    <% } %>
                </div>
            </div>
        </section>
    </main>
</body>
</html>
