<!DOCTYPE html>
<html lang="id">
<head>
    <%- include('layout/head') %>
</head>
<body class="pb-24 pt-16 md:pt-20 lg:pt-24 animate-fade">
    <%- include('layout/navbar') %>

    <main class="container mx-auto px-4 py-6 md:py-8 lg:px-8">
        <header class="mb-8 md:mb-12 text-center md:text-left">
            <h1 class="text-2xl md:text-4xl lg:text-5xl font-black text-white mb-2 md:mb-4">Jadwal Rilis</h1>
            <p class="text-zinc-400 text-sm md:text-base lg:text-lg">Jangan lewatkan episode terbaru anime favoritmu.</p>
        </header>

        <section class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6 md:gap-8">
            <% schedule.forEach((day, index) => { %>
                <article class="glass-card rounded-2xl p-5 md:p-6 animate-slide" style="animation-delay: <%= index * 0.1 %>s;">
                    <header class="flex items-center gap-3 mb-4 md:mb-5 border-b border-white/5 pb-3 md:pb-4">
                        <div class="w-2 h-8 md:h-10 rounded-full bg-gradient-to-b from-purple-500 to-indigo-500"></div>
                        <h2 class="text-lg md:text-xl font-bold text-white uppercase tracking-wider"><%= day.day %></h2>
                    </header>
                    
                    <ul class="space-y-3 md:space-y-4">
                        <% day.list.forEach(anime => { %>
                            <li>
                                <a href="/anime/<%= anime.slug %>" class="flex items-center gap-3 md:gap-4 group hover:bg-white/5 p-2 md:p-3 -mx-2 md:-mx-3 rounded-lg transition-colors duration-300">
                                    <img src="<%= anime.img %>" alt="<%= anime.title %>" class="w-10 h-10 md:w-12 md:h-12 rounded-full object-cover border border-white/10 group-hover:border-purple-500 transition-colors duration-300 flex-shrink-0" loading="lazy">
                                    <div class="overflow-hidden flex-1">
                                        <h3 class="text-sm md:text-base font-medium text-zinc-300 group-hover:text-white truncate transition-colors duration-300"><%= anime.title %></h3>
                                        <time class="text-[10px] md:text-xs text-zinc-500 mt-1 block">Tayang hari ini</time>
                                    </div>
                                </a>
                            </li>
                        <% }) %>
                    </ul>
                </article>
            <% }) %>
        </section>
    </main>
</body>
</html>
