    .glass-card { background: linear-gradient(180deg, rgba(39,39,42,0.6) 0%, rgba(24,24,27,0.6) 100%); border: 1px solid rgba(255,255,255,0.08); backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px); }

    .animate-fade { animation: fadeIn 0.3s cubic-bezier(0.4, 0, 0.2, 1) forwards; }
    .animate-slide { animation: slideUp 0.4s cubic-bezier(0.16, 1, 0.3, 1) forwards; opacity: 0; transform: translateY(10px); }

    @keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }
    @keyframes slideUp { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }

    .active-nav { color: var(--primary); }
    .active-nav svg { fill: rgba(139, 92, 246, 0.15); stroke: var(--primary); }
</style>

